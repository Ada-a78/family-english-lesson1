  "did_plus_base_rule": {
    "title": "疑问句中 did 后面必须用动词原形",
    "explanation_cn": "did 已经表示过去，所以后面的主要动词回到原形。",
    "examples": [
      [
        "Where did you go?",
        "did + go，不能说 did went。"
      ],
      [
        "What did you do?",
        "did + do，不能说 did did。"
      ],
      [
        "How did you get there?",
        "did + get，不能说 did got。"
      ]
    ]
  },
